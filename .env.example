# ! File in use lies in root directory named ".env", this is an example file only !
# =============================================================================
# COMMON (shared across all regions)
# =============================================================================

# Raspberry Pi
RASPBERRYPI_LOGIN=your_login
RASPBERRYPI_PW=your_password

# GL KVM
GLKVM_LOGIN=your_login
GLKVM_PW=your_password

# Proxmox
PROXMOX_LOGIN=your_login
PROXMOX_PW=your_password

# Home Assistant — Advanced SSH & Web Terminal
HA_SSH_LOGIN=your_login
HA_SSH_PW=your_password

# =============================================================================
# BG
# =============================================================================

# Raspberry Pi
BG_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BG_HA_URL=http://bg-homeassistant:8123
BG_HA_TOKEN=your_long_lived_access_token

# WhatsApp — sent via the shared bnu WAHA (LAN → Tailscale socat chain via bg-proxmox :3001)
BG_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# BNU
# =============================================================================

# Raspberry Pi
BNU_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BNU_HA_URL=http://bnu-homeassistant:8123
BNU_HA_TOKEN=your_long_lived_access_token

# WhatsApp — Casa Blumenau group JID (mirror into bnu-homeassistant secrets.yaml as whatsapp_group_jid)
BNU_WHATSAPP_GROUP_JID=____@g.us

# WhatsApp — WAHA (sole WhatsApp gateway; serves all regions). Runs in LXC 101 "docker"
# @ 10.1.1.126:3000, NOWEB engine, session persisted. Mirror into bnu-homeassistant
# secrets.yaml as: waha_api_url, waha_api_key, waha_session
BNU_WAHA_API_URL=http://10.1.1.126:3000
BNU_WAHA_API_KEY=generate_with__openssl_rand_hex_32
BNU_WAHA_SESSION=default
BNU_WAHA_DASHBOARD_USER=admin
BNU_WAHA_DASHBOARD_PASS=generate_with__openssl_rand_hex_12

# Frigate Digest — OpenAI (cloud LLM; also the automatic fallback when local Ollama fails).
# Mirror into bnu-homeassistant secrets.yaml as: openai_api_key
BNU_HA_FRIGATE_OPENAI_API_KEY=sk-...

# Frigate Debug — add to bnu-homeassistant secrets.yaml: whatsapp_smoketest_jid: <value>
# Uses the same group as SMOKETESTS_WHATSAPP_GROUP_JID (see bottom of this file)

# =============================================================================
# PLY
# =============================================================================

# Raspberry Pi
PLY_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
PLY_HA_URL=http://ply-homeassistant:8123
PLY_HA_TOKEN=your_long_lived_access_token

# WhatsApp — sent via the shared bnu WAHA (Tailscale; PLY cutover pending)
PLY_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# FLN
# =============================================================================

# Home Assistant
FLN_HA_URL=http://fln-homeassistant:8123
FLN_HA_TOKEN=your_long_lived_access_token

# WhatsApp — sent via the shared bnu WAHA (Tailscale)
FLN_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# SMOKETESTS
# =============================================================================

# WhatsApp group used for integration testing (shared bnu WAHA)
SMOKETESTS_WHATSAPP_GROUP_JID=____@g.us
