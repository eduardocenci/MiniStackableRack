# ! File in use lies in root directory named ".env", this is an example file only !
# =============================================================================
# COMMON (shared across all regions)
# =============================================================================

# Raspberry Pi
RASPBERRYPI_LOGIN=your_login
RASPBERRYPI_PW=your_password

# GL KVM
GLKVM_LOGIN=your_login
GLKVM_PW=your_password

# Proxmox
PROXMOX_LOGIN=your_login
PROXMOX_PW=your_password

# Proxmox API for globalnet /api/node-stats (load bars).
# Prefer scoped tokens (pveum user token add root@pam globalnet --privsep 1
# + pveum acl modify / --tokens 'root@pam!globalnet' --roles PVEAuditor):
# PVE_TOKEN_BNU=root@pam!globalnet=your_token_uuid  (same for PLY/BG/FLN)
# Fallback: ticket auth with the root credentials
PVE_USER=root@pam
PVE_PASSWORD=your_password

# PLY UniFi controller for globalnet /api/wan-usage (live WAN throughput).
# Must be a LOCAL-ONLY UniFi admin (view-only role suffices) — Ubiquiti SSO
# accounts require MFA and cannot log in via the API. Reached through the
# unifi-proxy.service socat relay on ply-proxmox (:8443 -> 192.168.0.1:443).
PLY_UNIFI_URL=https://ply-proxmox:8443
PLY_UNIFI_USER=your_login
PLY_UNIFI_PASSWORD=your_password

# Home Assistant — Advanced SSH & Web Terminal
HA_SSH_LOGIN=your_login
HA_SSH_PW=your_password

# =============================================================================
# BG
# =============================================================================

# Raspberry Pi
BG_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BG_HA_URL=http://bg-homeassistant:8123
BG_HA_TOKEN=your_long_lived_access_token

# WhatsApp (shared Evolution API hosted on bnu-docker; reachable via Tailscale)
BG_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# BNU
# =============================================================================

# Raspberry Pi
BNU_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BNU_HA_URL=http://bnu-homeassistant:8123
BNU_HA_TOKEN=your_long_lived_access_token

# WhatsApp — Evolution API (legacy; still serves BG/PLY). Hosted in LXC 101 "docker".
BNU_WHATSAPP_API_KEY=key
BNU_WHATSAPP_GROUP_JID=____@g.us

# WhatsApp — WAHA (replaces Evolution for bnu). Runs in LXC 101 "docker" @ 10.1.1.126:3000,
# NOWEB engine, session persisted. Mirror into bnu-homeassistant secrets.yaml as:
#   waha_api_url, waha_api_key, waha_session
BNU_WAHA_API_URL=http://10.1.1.126:3000
BNU_WAHA_API_KEY=generate_with__openssl_rand_hex_32
BNU_WAHA_SESSION=default
BNU_WAHA_DASHBOARD_USER=admin
BNU_WAHA_DASHBOARD_PASS=generate_with__openssl_rand_hex_12

# Frigate Digest — OpenAI (only needed when Digest LLM = "OpenAI (cloud)" or "Both")
BNU_OPENAI_API_KEY=sk-...

# Frigate Debug — add to bnu-homeassistant secrets.yaml: whatsapp_smoketest_jid: <value>
# Uses the same group as SMOKETESTS_WHATSAPP_GROUP_JID (see bottom of this file)

# =============================================================================
# PLY
# =============================================================================

# Raspberry Pi
PLY_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
PLY_HA_URL=http://ply-homeassistant:8123
PLY_HA_TOKEN=your_long_lived_access_token

# WhatsApp (shared Evolution API hosted on bnu-docker; reachable via Tailscale)
PLY_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# FLN
# =============================================================================

# Home Assistant
FLN_HA_URL=http://fln-homeassistant:8123
FLN_HA_TOKEN=your_long_lived_access_token

# WhatsApp (shared Evolution API hosted on bnu-docker; reachable via Tailscale)
FLN_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# SMOKETESTS
# =============================================================================

# WhatsApp group used for integration testing (shared Evolution API)
SMOKETESTS_WHATSAPP_GROUP_JID=____@g.us
