# ! File in use lies in root directory named ".env", this is an example file only !
# =============================================================================
# COMMON (shared across all regions)
# =============================================================================

# Raspberry Pi
RASPBERRYPI_LOGIN=your_login
RASPBERRYPI_PW=your_password

# GL KVM
GLKVM_LOGIN=your_login
GLKVM_PW=your_password

# Proxmox
PROXMOX_LOGIN=your_login
PROXMOX_PW=your_password

# Home Assistant — Advanced SSH & Web Terminal
HA_SSH_LOGIN=your_login
HA_SSH_PW=your_password

# =============================================================================
# BG
# =============================================================================

# Raspberry Pi
BG_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BG_HA_URL=http://bg-homeassistant:8123
BG_HA_TOKEN=your_long_lived_access_token

# =============================================================================
# BNU
# =============================================================================

# Raspberry Pi
BNU_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
BNU_HA_URL=http://bnu-homeassistant:8123
BNU_HA_TOKEN=your_long_lived_access_token

# WhatsApp (Evolution API — bnu-docker VM)
BNU_WHATSAPP_API_KEY=key
BNU_WHATSAPP_GROUP_JID=____@g.us

# =============================================================================
# PLY
# =============================================================================

# Raspberry Pi
PLY_RASPBERRYPI_HOST_KEY=your_host_key

# Home Assistant
PLY_HA_URL=http://ply-homeassistant:8123
PLY_HA_TOKEN=your_long_lived_access_token
